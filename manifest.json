{
  "manifest_version": 3,
  "name": "Ads Grabber",
  "description": "Ads Grabber: Meta Ads Library tools.",
  "version": "1.1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.facebook.com/ads/library*",
    "https://web.facebook.com/ads/library*",
    "https://www.adsgrabber.org/*",
    "<all_urls>"
  ],
  "omnibox": {
    "keyword": "@ads"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/ads/library*",
        "https://web.facebook.com/ads/library*"
      ],
      "js": [
        "content-filter.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.facebook.com/ads/library*",
        "https://web.facebook.com/ads/library*"
      ],
      "js": [
        "meta-ads-downloader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Ads Grabber"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}